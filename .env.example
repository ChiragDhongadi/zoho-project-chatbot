# FastAPI configuration
HOST=127.0.0.1
PORT=8000
SECRET_KEY=generate_a_random_32_char_secret_key_here
FRONTEND_URL=http://localhost:5173

# Zoho OAuth Credentials 
ZOHO_CLIENT_ID=your_zoho_client_id
ZOHO_CLIENT_SECRET=your_zoho_client_secret
ZOHO_REDIRECT_URI=http://localhost:8000/auth/callback
ZOHO_PORTAL_ID=your_zoho_portal_id_or_empty_to_auto_detect
ZOHO_DOMAIN=zoho.in

# LLM Provider Configuration
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# LangSmith Observability (Optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_PROJECT=zoho-projects-chatbot
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# Guardrails Model Configuration
GROQ_GUARDRAIL_MODEL=llama-3.1-8b-instant
